    {
      "name": "List Single User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "/*\r",
              "========================\r",
              " Root structure\r",
              "========================\r",
              "*/\r",
              "pm.test(\"Response has main objects\", function () {\r",
              "    pm.expect(response).to.have.all.keys('data', 'support', '_meta');\r",
              "});\r",
              "\r",
              "/*\r",
              "========================\r",
              " Data object structure\r",
              "========================\r",
              "*/\r",
              "pm.test(\"Data object has correct structure\", function () {\r",
              "    pm.expect(response.data).to.have.all.keys(\r",
              "        'id',\r",
              "        'email',\r",
              "        'first_name',\r",
              "        'last_name',\r",
              "        'avatar'\r",
              "    );\r",
              "});\r",
              "\r",
              "/*\r",
              "========================\r",
              " Data object types & values\r",
              "========================\r",
              "*/\r",
              "pm.test(\"Data object fields have correct types\", function () {\r",
              "    pm.expect(response.data.id).to.be.a('number');\r",
              "    pm.expect(response.data.first_name).to.be.a('string');\r",
              "    pm.expect(response.data.last_name).to.be.a('string');\r",
              "    pm.expect(response.data.avatar).to.be.a('string');\r",
              "    pm.expect(response.data.avatar).to.match(/^https?:\\/\\/.+/);\r",
              "});\r",
              "\r",
              "//validate email formate\r",
              "pm.test(\"Email format is valid\", function () {\r",
              "    email = response.data.email;\r",
              "\r",
              "    pm.expect(email).to.be.a('string');\r",
              "\r",
              "    const emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\r",
              "    pm.expect(email).to.match(emailRegex);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
