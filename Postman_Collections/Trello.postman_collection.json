  "item": [
    {
      "name": "Create Board",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsondata = pm.response.json();\r",
              "pm.collectionVariables.set(\"boardID\", jsondata.id);\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Correct Board Name\", function () {\r",
              "    pm.expect(jsondata.name).to.eql(\"Aya_board\");\r",
              "});\r",
              "\r",
              "\r",
              "// Test to check if 'permissionLevel' is equal to 'private'\r",
              "pm.test(\"Permission level is 'private'\", function () {\r",
              "    pm.expect(jsondata).to.have.property('prefs').that.has.property('permissionLevel', 'private');\r",
              "});\r",
              "\r",
              "\r",
              "// Test for presence of 'name', 'desc', and 'url' specifically\r",
              "pm.test(\"Fields 'name', 'desc', and 'url' are present\", function () {\r",
              "    pm.expect(jsondata.name).to.exist;\r",
              "    pm.expect(jsondata.desc).to.exist;\r",
              "    pm.expect(jsondata.url).to.exist;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
